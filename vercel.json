{
 "version": 2,
 "cleanUrls": true,
 "routes": [
    { "src": "^/assets/(.*)$", "dest": "/assets/$1" },
    { "src": "^/allcss/(.*)$", "dest": "/allcss/$1" },
    { "src": "^/(deriv-logo\\.svg|boxicons\\.min\\.css|robots\\.txt)$", "dest": "/$1" },
    { "src": "^/(.*)\\.html$", "dest": "/$1.html" },
    { "src": "^/(.*)$", "dest": "/index.html" }
  ]
}